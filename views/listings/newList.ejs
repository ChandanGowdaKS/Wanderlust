<% layout("/layouts/boilerplate") -%> <br /><br />
<div class="row mt-3">
  <div class="col-8 offset-2">
    <h3>Create Your New Listing</h3>
    <br />
    <form method="POST" action="/listings" novalidate class="needs-validation">
      <div class="mb-3">
        <label for="title" class="form-label fw-bold">Title :</label>
        <input
          name="listing[title]"
          type="text"
          placeholder="Enter the title"
          class="form-control"
          required
        />
        <div class="invalid-feedback">Please enter the Title</div>
        <div class="valid-feedback">Title looks good</div>
      </div>
      <div class="mb-3">
        <label for="description" class="form-label fw-bold"
          >Description:
        </label>
        <textarea
          name="listing[description]"
          class="form-control"
          rows=""
          cols=""
          type="text"
          required
        ></textarea>
        <div class="invalid-feedback">Please enter the Description</div>
      </div>
      <div class="mb-3">
        <label for="image.url" class="form-label fw-bold">Image URL :</label>
        <input
          name="listing[image][url]"
          class="form-control"
          placeholder="(Leave empty for default image)"
          value="https://cdn.pixabay.com/photo/2024/05/01/12/59/nature-8732304_1280.jpg"
        />
      </div>
      <div class="row">
        <div class="mb-3 col-md-4">
          <label for="price" class="form-label fw-bold">Price :</label>
          <input
            name="listing[price]"
            type="number"
            class="form-control"
            placeholder="1,500"
            required
          />
          <div class="invalid-feedback">Please enter the valid price</div>
        </div>
        <div class="mb-3 col-md-8">
          <label for="country" class="form-label fw-bold">Country:</label>
          <input
            name="listing[country]"
            type="text"
            class="form-control"
            placeholder="India"
            required
          />
          <div class="invalid-feedback">Please enter the Country name</div>
        </div>
      </div>

      <div class="mb-3">
        <label for="location" class="form-label fw-bold">Location:</label>
        <input
          name="listing[location]"
          type="text"
          class="form-control"
          placeholder="Bengaluru,India"
          required
        />
        <div class="invalid-feedback">Please enter the Location</div>
      </div>

      <button class="btn btn-dark">Create</button>
    </form>
  </div>
</div>
<br /><br />
