<% layout("/layouts/boilerplate") -%>
<body>
    <h3>All Information about <%=list.title  %></h3>
    <ul>

    <li> <%= list.title %></li>
    <br>
    <li> <%= list.description %></li><br>
    <li><%= list.image.filename %></li><br>
    <img src="<%= list.image.url %>" width="250" ><br><br>
    <li> &#8377 <%=list.price.toLocaleString("en-IN") %></li><br>
    <li> <%=list.location %></li><br>
    <li> <%=list.country %></li>

</ul>
<a  href = "/listings/<%= list._id %>/edit">Edit this list</a>
<br> <br>
<form method = "POST" action = "/listings/<%= list._id %>?_method=DELETE">
    <button>Delete this List</button>
</form>

</body>

