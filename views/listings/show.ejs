<% layout("/layouts/boilerplate") -%>
<div class="row mt-3">
    <div class="col-8 offset-3">

    
    <h3 class="text-primary">All Information about <b><%=list.title  %></b></h3>
    </div>
    <div class="col-6 offset-3 listing-card">
        <img src = "<%= list.image.url %>" width="250" class = "show-img card-img-top"> 
        <div class="card-body mt-2">
            <p class="card-text"><i> Owned by :<%= list.owner ? list.owner.username : "Owner not assigned" %></i></p>
            <p class ="m-2"><b class="card-text"> Place: <i><%= list.title %></i></p>
        <p class="card-text"> Description: <%= list.description %></p>
        <p class="card-text">Price: &#8377 <%=list.price.toLocaleString("en-IN") %></p>
        <p class="card-text">Location: <%=list.location %></p>
        <p class="card-text">Country:<%=list.country %></p>
    
  </div>
    </div>

        <div class="btns">

        <a  href = "/listings/<%= list._id %>/edit" class="btn btn-dark col-1 offset-3 edit-btn">Edit</a>
    
    <form method = "POST" action = "/listings/<%= list._id %>?_method=DELETE">
    <button class="btn  btn-dark offset-5">Delete</button>
    
    </form>
    </div>

<div class="col-8 offset-3 mb-3">
    <hr>
    <h4>Leave your review</h4>
    <form action="/listings/<%= list._id %>/reviews" method ="POST" novalidate class = "needs-validation">
        <div class = "mb-3 mt-3">
        <label for = "rating" class = "form-label">Rating</label>
        
        
        <input type="range" min="1" max="5" id ="rating" name = "review[rating]" class = "form-range">
        </div>
        <div class="mb-3 mt-3">
        <label for = "comment" class = "form-label">Comment</label>
        <textarea name="review[comment]" id="comment" class="form-control" rows="5" cols="10" required></textarea>
        <div class="invalid-feedback">
            Please submit some comments
        </div>
        </div>
        <button class="btn btn-outline-dark">Submit</button>
    </form>
    <hr>

    <p><b>All Reviews</b></p>
<div class="row ">
    <% for(review of list.reviews) { %>
        <div class="card col-5 ms-3 mb-3">
            <div class="card-body">
                <h5 class="card-title">@ <%= review.author ? review.author.username : "Anonymous" %></h5>
                <p class = "card-text"><%= review.comment %></p>
                <p class = "card-text"><%= review.rating %> Stars</p>
                <form method ="POST" action = "/listings/<%= list._id %>/reviews/<%= review._id %>?_method=DELETE">
                    <button class="btn btn-sm btn-dark mb-2">Delete</button>
                </form>
            </div>
        </div>
    <%} %>
    
</div>
    
</div>
</div>


